---
// @ts-nocheck
import BaseLayout from "../layouts/BaseLayout.astro";

import TitleSimple from "@/components/titulos/TitleSimple/TitleSimple.astro"

import { Banner } from "@/components/banners/Banner";
import { PostsContainer } from "@/components/posts/PostsContainer";
import { BtnAviso } from "@/components/buttons/BtnAviso";

import BannerVideo from "@/components/banners/BannerVideo/BannerVideo.astro";

// BANNER IMAGES
import bannerImg1 from "../assets/homeBanner/Artboard1.jpg";
import bannerImg2 from "../assets/homeBanner/Artboard2.jpg";
import bannerImg3 from "../assets/homeBanner/Artboard3.jpg";
import bannerImg4 from "../assets/homeBanner/Artboard4.jpg";

// BANNER VIDEO
import videFillerMp4 from "../assets/homeBanner/Filler_Imaginatio_720.mp4"

const bannerImages = [
  { src: bannerImg1.src, alt: "Banner 1", bg:"#32a852"},
  { src: bannerImg2.src, alt: "Banner 2", bg:"#32a2a8"},
  { src: bannerImg3.src, alt: "Banner 3", bg:"#3632a8"},
  { src: bannerImg4.src, alt: "Banner 4", bg:"#a8325c"},
];
---

<BaseLayout title="Imaginatio">
	<!-- <Banner 
		client:load 
		images={bannerImages}
	/> -->
	
	<!-- <BannerVideo
		video={videFillerMp4}
	/> -->
	
	<main>
		<div class="video-bg">
			<video muted autoplay loop>
				<source src={videFillerMp4}>
			</video>
		</div>

		<section class="parrafo-intro">
			<div>
				<p>Participa en el <strong>IMAGINATIO XVIII.</strong> Demuestra tus habilidades y tu creatividad en la creación de proyectos desarrollados en las asignaturas y en los semilleros de investigación. Destácate al resolver un reto de manera original o participa con tus amigos en el <strong>Mundialito de Fútbol 5.</strong></p>
				<p>El próximo <strong>7 y 8 de mayo</strong> tendremos <strong>actividades académicas y lúdicas</strong> para los integrantes del programa, que sin duda nos dejarán sorprendidos y motivados por ser parte de <strong>Ingeniería en Multimedia</strong> y <strong>orgullosos representantes del IMAGINATIO.</strong></p>
			</div>
		</section>

		<section class="container-btn">
			<BtnAviso client:visible>
				<a href="/muestra-academica">Feria de Projectos</a>
			</BtnAviso>

			<BtnAviso client:visible>
				<a href="/reto-economia-c">Reto</a>
			</BtnAviso>

			<BtnAviso client:visible>
				<a href="/mundialito">Mundialito</a>
			</BtnAviso>

			<BtnAviso client:visible>
				<a href="/super-smash">Torneo Smash</a>
			</BtnAviso>
		</section>
	</main>

</BaseLayout>

<style>
	main {
		position: relative;
	}

	.video-bg {
		z-index: 1;
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
	}

	.video-bg video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.parrafo-intro, .container-btn {
		z-index: 2;
		position: relative;
	}
	
	.parrafo-intro {
		margin: 20px;
		margin-top: 50px;
	}

	.parrafo-intro > div{
		display: flex;
		flex-direction: column;
		gap: 1em;
		margin: 0 auto;
		padding: 30px;
		max-width: 800px;
		font-size: 1.5em;
		background-color: rgba(255, 255, 255, 0.65);
		border-radius: 20px;
	}

	.container-btn {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 20px;
		margin: 30px auto;
		max-width: 800px;
		width: 100%;
	}

	.container-btn a {
		display: block;
		padding: 20px;
		font-size: 2em;
		color:#fff;
		text-align: center;
	}

	@media screen and (max-width: 600px) {
		.container-btn {
			flex-direction: column;
		}	
	}
</style>