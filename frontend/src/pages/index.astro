---
// @ts-nocheck
import BaseLayout from "../layouts/BaseLayout.astro";

import TitleSimple from "@/components/titulos/TitleSimple/TitleSimple.astro"

import { Banner } from "@/components/banners/Banner";
import { PostsContainer } from "@/components/posts/PostsContainer";
import { BtnAviso } from "@/components/buttons/BtnAviso";

import BannerVideo from "@/components/banners/BannerVideo/BannerVideo.astro";

// BANNER IMAGES
import bannerImg1 from "../assets/homeBanner/Artboard1.jpg";
import bannerImg2 from "../assets/homeBanner/Artboard2.jpg";
import bannerImg3 from "../assets/homeBanner/Artboard3.jpg";
import bannerImg4 from "../assets/homeBanner/Artboard4.jpg";

// BANNER VIDEO
import videFillerMp4 from "../assets/homeBanner/Filler_Imaginatio_720.mp4"

const bannerImages = [
  { src: bannerImg1.src, alt: "Banner 1", bg:"#32a852"},
  { src: bannerImg2.src, alt: "Banner 2", bg:"#32a2a8"},
  { src: bannerImg3.src, alt: "Banner 3", bg:"#3632a8"},
  { src: bannerImg4.src, alt: "Banner 4", bg:"#a8325c"},
];
---

<BaseLayout title="Imaginatio">
	<!-- <Banner 
		client:load 
		images={bannerImages}
	/> -->
	
	<BannerVideo
		video={videFillerMp4}
	/>
	
	<main>
		<TitleSimple
			titulo="Imaginatio XVIII"
			subtitulo="Demuestra tus conocimientos en el Imaginatio, participando en los torneos hechos para todos sín importar el nivel"
		/>

		<div>
			<BtnAviso client:visible>
				<a href="/concursos">Concursos</a>
			</BtnAviso>
			<BtnAviso client:visible>
				<a href="/mundialito">Mundial de Futbol</a>
			</BtnAviso>
		</div>
	</main>

</BaseLayout>

<style>
	div {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		margin: 20px 0;
	}

	a {
		display: block;
		padding: 20px;
		font-size: 2em;
		color:#fff
	}
</style>