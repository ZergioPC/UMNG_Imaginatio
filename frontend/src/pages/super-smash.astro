---
// @ts-nocheck
import Image from "astro/components/Image.astro";

import { BtnAviso } from "@/components/buttons/BtnAviso";
import TitleSimple from "@/components/titulos/TitleSimple/TitleSimple.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

import poster1 from "@/assets/torneoSmash/poster_1.jpg"
import poster2 from "@/assets/torneoSmash/poster_2.jpg"
import poster3 from "@/assets/torneoSmash/poster_3.jpg"
---

<BaseLayout title="Mascota">
  <TitleSimple 
    titulo="Torneo UMNG Campus" 
  />

  <div class="img-container">
    <img src={poster1.src} alt="Poster 1">
    <img src={poster2.src} alt="Poster 2">
    <img src={poster3.src} alt="Poster 3">
  </div>

  <div class="boton-insc">
    <BtnAviso client:visible>
      <a 
        href="https://www.start.gg/tournament/torneo-smash-bros-a-la-universidad/details"
        target="_blank"
      >Inscripciones</a>
    </BtnAviso>
  </div>

  
</BaseLayout>

<style>  
  .img-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    margin: 10px;
  }

  img {
    width: 100%;
    max-width: 80vh;
    border-radius: 20px;
    box-shadow: 4px 4px 5px rgba(0, 0, 0, .5);
  }

  .boton-insc {
    box-sizing: border-box;
    padding: 10px;
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.5);
  }

  .boton-insc a {
    color: #fff;
    font-size: 1.4em;
  }
</style>