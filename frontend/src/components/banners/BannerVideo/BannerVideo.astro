---
const Video = Astro.props.video;
---

<div>
  <video class="video-main" autoplay muted loop>
    <source src={Video}>
  </video>
  <video class="video-shadow" autoplay muted loop>
    <source src={Video}>
  </video>
</div>

<style>
  div {
    position: relative;
    box-sizing: border-box;
    margin: 10px auto;
    width: 100%;
    max-width: 900px;
    height: 400px;
    background-color: #000;
    overflow: hidden;
    border-radius: 20px;
  }

  .video-main {
    z-index: 2;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .video-shadow {
    position: relative;
    top: -100%;
    width: 100%;
    height: 100%;
    transform: scale(1.04);
    filter: blur(25px);
  }
</style>